<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="coffee">
        <createTable tableName="DRAFT_ORDER">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DRAFT_ORDER"/>
            </column>
            <column name="TOTAL" type="BIGINT"/>
            <column name="CUSTOMER_PHONE" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="coffee">
        <addColumn tableName="PRODUCT">
            <column name="DRAFT_ORDER_ID" type="UUID"/>
        </addColumn>
    </changeSet>
    <changeSet id="3" author="coffee">
        <createIndex indexName="IDX_PRODUCT_DRAFT_ORDER" tableName="PRODUCT">
            <column name="DRAFT_ORDER_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="DRAFT_ORDER_ID" baseTableName="PRODUCT"
                                 constraintName="FK_PRODUCT_ON_DRAFT_ORDER" referencedColumnNames="ID"
                                 referencedTableName="DRAFT_ORDER"/>
    </changeSet>
</databaseChangeLog>