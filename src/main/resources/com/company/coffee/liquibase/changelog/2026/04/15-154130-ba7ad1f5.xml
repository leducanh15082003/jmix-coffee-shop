<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="coffee">
        <createTable tableName="ORDER_PRODUCT_LINK">
            <column name="ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_ORDER_PRODUCT_LINK"/>
            </column>
            <column name="PRODUCT_ID" type="UUID"/>
            <column name="ORDER_ID" type="UUID"/>
            <column name="QUANTITY" type="INT"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="coffee">
        <createIndex indexName="IDX_ORDER_PRODUCT_LINK_ORDER" tableName="ORDER_PRODUCT_LINK">
            <column name="ORDER_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="ORDER_ID" baseTableName="ORDER_PRODUCT_LINK"
                                 constraintName="FK_ORDER_PRODUCT_LINK_ON_ORDER" referencedColumnNames="ID"
                                 referencedTableName="ORDER_"/>
    </changeSet>
    <changeSet id="3" author="coffee">
        <createIndex indexName="IDX_ORDER_PRODUCT_LINK_PRODUCT" tableName="ORDER_PRODUCT_LINK">
            <column name="PRODUCT_ID"/>
        </createIndex>

        <addForeignKeyConstraint baseColumnNames="PRODUCT_ID" baseTableName="ORDER_PRODUCT_LINK"
                                 constraintName="FK_ORDER_PRODUCT_LINK_ON_PRODUCT" referencedColumnNames="ID"
                                 referencedTableName="PRODUCT"/>
    </changeSet>
</databaseChangeLog>