<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="coffee">
        <dropForeignKeyConstraint baseTableName="product" constraintName="fk_product_on_draft_order"/>
    </changeSet>
    <changeSet id="2" author="coffee">
        <createTable tableName="DRAFT_ORDER_PRODUCT_LINK">
            <column name="DRAFT_ORDER_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DRAFT_ORDER_PRODUCT_LINK"/>
            </column>
            <column name="PRODUCT_ID" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_DRAFT_ORDER_PRODUCT_LINK"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="3" author="coffee">
        <addForeignKeyConstraint baseColumnNames="DRAFT_ORDER_ID" baseTableName="DRAFT_ORDER_PRODUCT_LINK"
                                 constraintName="FK_DRAORDPRO_ON_DRAFT_ORDER" referencedColumnNames="ID"
                                 referencedTableName="DRAFT_ORDER"/>
    </changeSet>
    <changeSet id="4" author="coffee">
        <addForeignKeyConstraint baseColumnNames="PRODUCT_ID" baseTableName="DRAFT_ORDER_PRODUCT_LINK"
                                 constraintName="FK_DRAORDPRO_ON_PRODUCT" referencedColumnNames="ID"
                                 referencedTableName="PRODUCT"/>
    </changeSet>
</databaseChangeLog>